<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground layer for ZenPatch.

  Design: a stylised "Z" patch badge on a transparent ground.
  The outer rounded-rect simulates a patch/badge shape.
  The "Z" letterform is drawn as two diagonal path segments.

  Canvas is 108×108 dp (safe zone 72×72 dp centred at 54,54).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Badge shape (rounded square, centred in safe zone) -->
    <path
        android:fillColor="#BB86FC"
        android:pathData="M54,22
            C54,22 78,22 82,26
            C86,30 86,54 86,54
            C86,54 86,78 82,82
            C78,86 54,86 54,86
            C54,86 30,86 26,82
            C22,78 22,54 22,54
            C22,54 22,30 26,26
            C30,22 54,22 Z"/>

    <!-- "Z" — top-left serif corner -->
    <path
        android:fillColor="#1A0533"
        android:pathData="M35,38 L73,38 L73,44 L42,64 L73,64 L73,70 L35,70 L35,64 L66,44 L35,44 Z"/>
</vector>
